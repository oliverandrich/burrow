package templates

import "codeberg.org/oliverandrich/burrow"

// AdminIndex renders the admin dashboard page with the given navigation items.
templ AdminIndex(items []burrow.NavItem) {
	<h1>Admin</h1>
	if len(items) > 0 {
		<nav>
			<ul>
				for _, item := range items {
					<li><a href={ templ.SafeURL(item.URL) }>{ item.Label }</a></li>
				}
			</ul>
		</nav>
	}
}
