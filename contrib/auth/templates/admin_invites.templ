package templates

import "fmt"
import "codeberg.org/oliverandrich/burrow/contrib/bsicons"
import "codeberg.org/oliverandrich/burrow/contrib/auth"
import "codeberg.org/oliverandrich/burrow/contrib/csrf"
import "codeberg.org/oliverandrich/burrow/contrib/i18n"

// adminInvitesPage renders the admin invites management page.
templ adminInvitesPage(invites []auth.Invite, createdURL string, useEmail bool) {
	<div class="d-flex justify-content-between align-items-center mb-2">
		<h2 class="mb-0">{ i18n.T(ctx, "admin-invites-title") }</h2>
	</div>
	<nav aria-label="breadcrumb" class="mb-4">
		<ol class="breadcrumb">
			<li class="breadcrumb-item"><a href="/admin/">Admin</a></li>
			<li class="breadcrumb-item active" aria-current="page">{ i18n.T(ctx, "admin-invites-title") }</li>
		</ol>
	</nav>
	<template id="icon-check-lg">@bsicons.CheckLg()</template>
	if createdURL != "" {
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			<strong>{ i18n.T(ctx, "admin-invites-created") }</strong>
			<div class="d-flex align-items-center gap-2 mt-1">
				<code class="flex-grow-1 text-break">{ createdURL }</code>
				<button
					type="button"
					class="btn btn-outline-success btn-sm flex-shrink-0"
					onclick={ copyToClipboard(createdURL, i18n.T(ctx, "admin-invites-copy-done")) }
					title={ i18n.T(ctx, "admin-invites-copy") }
				>
					@bsicons.Clipboard()
					{ i18n.T(ctx, "admin-invites-copy") }
				</button>
			</div>
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	}
	<div class="card mb-4">
		<div class="card-header">
			<h5 class="card-title mb-0">{ i18n.T(ctx, "admin-invites-create-title") }</h5>
		</div>
		<div class="card-body">
			<form method="post" action="/admin/invites">
				<input type="hidden" name="gorilla.csrf.Token" value={ csrf.Token(ctx) }/>
				<div class="mb-3">
					<label for="label" class="form-label">{ i18n.T(ctx, "admin-invites-label") }</label>
					<input type="text" class="form-control" id="label" name="label" placeholder={ i18n.T(ctx, "admin-invites-label-placeholder") }/>
				</div>
				if useEmail {
					<div class="mb-3">
						<label for="email" class="form-label">{ i18n.T(ctx, "admin-invites-email-label") }</label>
						<input type="email" class="form-control" id="email" name="email" placeholder="user@example.com" required/>
					</div>
				}
				<button type="submit" class="btn btn-primary">{ i18n.T(ctx, "admin-invites-create-button") }</button>
			</form>
		</div>
	</div>
	<h4 class="mb-3">{ i18n.T(ctx, "admin-invites-existing-title") }</h4>
	if len(invites) > 0 {
		<div class="table-responsive">
			<table class="table table-striped table-hover table-sm align-middle">
				<thead>
					<tr>
						<th scope="col">{ i18n.T(ctx, "admin-invites-label") }</th>
						if useEmail {
							<th scope="col">{ i18n.T(ctx, "admin-invites-email") }</th>
						}
						<th scope="col">{ i18n.T(ctx, "admin-invites-status") }</th>
						<th scope="col">{ i18n.T(ctx, "admin-invites-expires") }</th>
						<th scope="col"></th>
					</tr>
				</thead>
				<tbody>
					for _, inv := range invites {
						<tr>
							<td>{ inv.Label }</td>
							if useEmail {
								<td>{ inv.Email }</td>
							}
							<td>
								if inv.IsUsed() {
									<span class="badge text-bg-secondary">{ i18n.T(ctx, "admin-invites-status-used") }</span>
								} else if inv.IsExpired() {
									<span class="badge text-bg-warning">{ i18n.T(ctx, "admin-invites-status-expired") }</span>
								} else {
									<span class="badge text-bg-success">{ i18n.T(ctx, "admin-invites-status-active") }</span>
								}
							</td>
							<td>{ inv.ExpiresAt.Format("2006-01-02") }</td>
							<td>
								if !inv.IsUsed() {
									<button
										type="button"
										class="btn btn-outline-danger btn-sm"
										hx-delete={ fmt.Sprintf("/admin/invites/%d", inv.ID) }
										hx-headers={ fmt.Sprintf(`{"X-CSRF-Token":"%s"}`, csrf.Token(ctx)) }
										hx-confirm={ i18n.T(ctx, "admin-invites-revoke-confirm") }
									>
										{ i18n.T(ctx, "admin-invites-revoke") }
									</button>
								}
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	} else {
		<div class="text-center py-4 text-body-secondary">
			@bsicons.Envelope("fs-1 d-block mb-2")
			<p>{ i18n.T(ctx, "admin-invites-none") }</p>
		</div>
	}
}

// copyToClipboard copies text to the clipboard and briefly changes the button label.
script copyToClipboard(text string, doneLabel string) {
	navigator.clipboard.writeText(text).then(function() {
		var btn = event.currentTarget;
		var original = btn.innerHTML;
		var iconSvg = document.getElementById('icon-check-lg').innerHTML; btn.innerHTML = iconSvg + ' ' + doneLabel;
		setTimeout(function() { btn.innerHTML = original; }, 2000);
	});
}
